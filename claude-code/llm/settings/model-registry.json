{
  "_meta": {
    "last_discovery": null,
    "tier1_count": 10,
    "tier2_count": 0,
    "tier3_count": 0,
    "total_count": 10,
    "_note": "tier1 = manually curated (never auto-overwritten), tier2 = auto-discovered notable, tier3 = auto-discovered everything else"
  },

  "providers": {
    "claude-cli":   { "note": "Claude Code CLI — uses your Claude login, no key needed", "api_style": "claude-cli" },
    "codex":        { "note": "Codex CLI — uses your ChatGPT login, no key needed", "api_style": "codex" },
    "kimi-cli":     { "note": "Kimi CLI — uses your Kimi login, no key needed", "api_style": "kimi-cli" },
    "google":       { "base_url": "https://generativelanguage.googleapis.com/v1beta", "env_key": "GOOGLE_API_KEY", "api_style": "google" },
    "openrouter":   { "base_url": "https://openrouter.ai/api/v1", "env_key": "OPENROUTER_API_KEY", "api_style": "openai" },
    "anthropic":    { "base_url": "https://api.anthropic.com/v1", "env_key": "ANTHROPIC_API_KEY", "api_style": "anthropic" },
    "moonshot":     { "base_url": "https://api.moonshot.cn/v1", "env_key": "MOONSHOT_API_KEY", "api_style": "openai" }
  },

  "models": {
    "opus": {
      "tier": 1,
      "_source": "manual",
      "description": "Claude Opus 4.6 — most capable Claude model, extended thinking inherent, 1M context",
      "context_length": 1000000,
      "route": "claude-cli",
      "reasoning": {"max_tokens": 16000},
      "routes": {
        "claude-cli":   { "api_model": "opus" },
        "openrouter":   { "api_model": "anthropic/claude-opus-4-6" },
        "anthropic":    { "api_model": "claude-opus-4-6" }
      }
    },
    "chatgpt-5.4": {
      "tier": 1,
      "_source": "manual",
      "description": "ChatGPT 5.4 — latest flagship coding model, 1M context, reasoning_effort=xhigh",
      "context_length": 1050000,
      "route": "codex",
      "reasoning": {"effort": "xhigh"},
      "reasoning_effort": "xhigh",
      "codex_config": {
        "model_context_window": 1000000,
        "model_auto_compact_token_limit": 900000,
        "stream_idle_timeout_ms": 300000,
        "_note": "Codex CLI caps at ~272K by default. These overrides enable the full 1M context. Accuracy degrades beyond 512K — stay under 272K for accuracy-critical work, use 1M for completeness tasks (large codebases, full-repo analysis)."
      },
      "routes": {
        "codex":        { "api_model": "chatgpt-5.4" },
        "openrouter":   { "api_model": "openai/chatgpt-5.4" }
      }
    },
    "gpt-5.3-codex": {
      "tier": 1,
