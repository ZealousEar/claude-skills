      "reasoning": {"effort": "xhigh"},
      "reasoning_effort": "xhigh",
      "routes": {
        "codex":        { "api_model": "gpt-5.3-codex" },
        "openrouter":   { "api_model": "openai/gpt-5.3" }
      }
    },
